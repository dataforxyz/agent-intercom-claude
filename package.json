{
  "name": "claude-intercom",
  "version": "0.1.0",
  "description": "Claude Code MCP plugin and wakeable worker for direct local messaging with Pi, Codex, and Claude coding-agent sessions.",
  "license": "MIT",
  "type": "module",
  "main": "dist/claude-server.mjs",
  "bin": {
    "claude-intercom-mcp": "dist/claude-server.mjs",
    "claude-intercom-worker": "dist/worker-daemon.mjs",
    "cci": "dist/cci.mjs"
  },
  "files": [
    "assets/**/*",
    "dist/**/*",
    "claude/**/*.ts",
    "broker/**/*.ts",
    "scripts/**/*",
    "skills/**/*",
    "types.ts",
    "config.ts",
    ".claude-plugin/**/*",
    ".mcp.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepare": "npm run build",
    "claude:mcp": "tsx claude/server.ts",
    "claude:worker": "tsx claude/worker-daemon.ts",
    "cci": "tsx claude/cci.ts",
    "test": "tsx --test broker/client.test.ts broker/framing.test.ts broker/paths.test.ts broker/spawn.test.ts claude/*.test.ts"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "intercom",
    "multi-agent",
    "pi",
    "codex"
  ],
  "devDependencies": {
    "esbuild": "^0.28.1",
    "tsx": "^4.20.0",
    "typescript": "^6.0.3"
  }
}
